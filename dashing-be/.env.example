# Dashing API Environment Configuration

# Server
PORT=3001
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://dashing:dashing_dev@localhost:5432/dashing?schema=public"

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
API_KEY_SALT=your-api-key-salt-change-in-production

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:9000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
